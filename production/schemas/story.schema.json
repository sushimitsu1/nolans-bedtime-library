{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nolan-library.local/schemas/story.schema.json",
  "title": "Nolan structured story",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "slug", "category", "description", "characterBible", "settingBible", "continuityRules", "pages"],
  "properties": {
    "title": {"type": "string", "minLength": 1},
    "slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "category": {"enum": ["Emergency Vehicles", "Construction Vehicles", "Monster Trucks", "Race Cars"]},
    "description": {"type": "string", "minLength": 1},
    "characterBible": {"type": "object", "minProperties": 1},
    "settingBible": {"type": "object", "minProperties": 1},
    "continuityRules": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "pages": {
      "type": "array",
      "minItems": 15,
      "maxItems": 15,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["number", "text", "illustrationScene", "requiredCharacters", "timeOfDay", "continuityNotes"],
        "properties": {
          "number": {"type": "integer", "minimum": 1, "maximum": 15},
          "text": {"type": "string", "minLength": 1},
          "illustrationScene": {"type": "string", "minLength": 1},
          "requiredCharacters": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "timeOfDay": {"type": "string", "minLength": 1},
          "continuityNotes": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
